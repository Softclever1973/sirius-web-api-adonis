# =====================================================
# SIRIUS WEB API - Variáveis de Ambiente
# =====================================================

# Copie este arquivo para .env e preencha com seus dados
# NUNCA commite o arquivo .env no Git!

# Banco de Dados PostgreSQL (Supabase)
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@[SEU_HOST].supabase.co:5432/postgres

# JWT Secret (gere uma string aleatória forte)
# Exemplo de geração: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua_chave_secreta_super_segura_aqui

# Porta da API
PORT=3000

# Ambiente (development, production)
NODE_ENV=development

# Token de expiração JWT
JWT_EXPIRES_IN=7d

# =====================================================
# COMO OBTER SUAS CREDENCIAIS:
# =====================================================
# 
# 1. DATABASE_URL:
#    - Acesse o Supabase: https://supabase.com/dashboard
#    - Entre no seu projeto
#    - Vá em: Settings > Database
#    - Copie a "Connection string" no formato "URI"
#    - Substitua [YOUR-PASSWORD] pela senha do seu banco
#
# 2. JWT_SECRET:
#    - Execute no terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#    - Copie o resultado e cole aqui
#
# =====================================================

# Configure o envio de email para os usuarios caso precisem alterar a senha
# Esses dados devem ser adquiridos baseados no provedor SMTP do email de uso, por exemplo
#   AUTH_HOST=smtp.gmail.com
#   AUTH_PORT=587
#   AUTH_EMAIL= exemplo@gmail.com
#   AUTH_PASSWORD= 123
# Os dados do SMTP podem ser adquiridos simplismente procurando SMTP gmail por exemplo

AUTH_HOST=[YourHostAddress]
AUTH_PORT=[YourHostPort]
AUTH_EMAIL= [YourExemploEmailHere@exemple.com]
AUTH_PASSWORD= [YourEmailPasswordHere]

# Utilizando True, cada alteração feita, seja adição, remoção ou edição, é registrada em detalhes em um banco de dados
# É Recomendado Ativar para saber quem fez quais mudanças
AUDIT_LOG_ENABLED=[true or false]